# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mikrokredito
DB_USER=postgres
DB_PASS=your_password
DB_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis (Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# File Upload
UPLOAD_DIR=./src/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp

# Email (SMTP)
SMTP_HOST=mail.otech.co.mz
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=comercial@otech.co.mz
SMTP_PASS=coloque_a_senha_do_email
EMAIL_FROM_NAME=OTECH - MikroKrédito MZ
EMAIL_FROM=comercial@otech.co.mz

# SMS - Twilio (fallback)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+14155238886

# SMS - Movitel/Vodacom MZ (primary)
MZ_SMS_GATEWAY_URL=https://api.sms.co.mz/v1/send
MZ_SMS_API_KEY=your_mz_sms_api_key
MZ_SMS_SENDER=MikroKred

# WhatsApp — sessão WhatsApp Web (whatsapp-web.js), sem API oficial da Meta.
# Não precisa de chaves: ligue em /super/whatsapp lendo o código QR com o telemóvel.
# PUPPETEER_EXECUTABLE_PATH só é necessário se o Chromium do sistema estiver noutro caminho
# (já configurado automaticamente no Dockerfile).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# M-Pesa (Vodacom Mozambique)
MPESA_ENV=sandbox
MPESA_API_KEY=your_mpesa_api_key
MPESA_PUBLIC_KEY=your_mpesa_public_key
MPESA_SERVICE_PROVIDER_CODE=171717
MPESA_INITIATOR_IDENTIFIER=your_initiator
MPESA_SECURITY_CREDENTIAL=your_credential
MPESA_CALLBACK_URL=https://api.mikrokredito.co.mz/api/v1/payments/callback/mpesa

# e-Mola (Movitel)
EMOLA_API_URL=https://api.emola.co.mz
EMOLA_API_KEY=your_emola_api_key
EMOLA_MERCHANT_ID=your_merchant_id
EMOLA_CALLBACK_URL=https://api.mikrokredito.co.mz/api/v1/payments/callback/emola

# Banco (Bank Transfer)
BANK_ACCOUNT_NAME=MikroKrédito MZ SARL
BANK_ACCOUNT_NUMBER=000123456789
BANK_SWIFT=BVMZMZMX
BANK_IBAN=MZ59000123456789

# Queue
QUEUE_CONCURRENCY=5
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MS=30000

# Frontend URL
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://mikrokredito.co.mz

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# SMTP Test Page
SMTP_TEST_DEFAULT_TO=comercial@otech.co.mz
